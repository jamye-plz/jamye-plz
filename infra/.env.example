# ============================================================
# jamye-plz infra — docker-compose environment
# Copy to infra/.env and adjust if you need non-default values.
# `podman compose` auto-loads infra/.env when run from this directory.
#
# Defaults match backend/.env.example so the backend connects with:
#   DATABASE_URL=postgresql+asyncpg://jamye:password@localhost:5432/jamye
# ============================================================

# --- Postgres -------------------------------------------------
POSTGRES_USER=jamye
POSTGRES_PASSWORD=password
POSTGRES_DB=jamye

# Host port exposed for the DB (container always listens on 5432).
# Change only if 5432 is already taken on your machine — then also
# update backend/.env DATABASE_URL to match.
POSTGRES_PORT=5432

# --- MinIO (S3-compatible object storage) ----------------------
MINIO_ROOT_USER=jamye-minio
MINIO_ROOT_PASSWORD=password12345

# Host ports for the MinIO API (9000) and web console (9001).
# Change only if already taken on your machine — then also update
# backend/.env MINIO_ENDPOINT to match the new API port.
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
