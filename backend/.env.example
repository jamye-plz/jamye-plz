# ============================================================
# jamye-plz backend — environment variables
# Copy to .env and fill in real values for production.
# Demo/dev works without real OAuth/VAPID keys (fallback paths
# are active when keys are absent — see core/config.py).
# ============================================================

# --- Database --------------------------------------------------
DATABASE_URL=postgresql+asyncpg://jamye:password@localhost:5432/jamye

# --- JWT -------------------------------------------------------
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
# seconds (7 days default)
JWT_EXPIRE_SECONDS=604800

# --- CORS ------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:5173

# --- Kakao OAuth -----------------------------------------------
# REST API key (= KAKAO_CLIENT_ID) from developers.kakao.com. Real OAuth turns
# on as soon as KAKAO_CLIENT_ID is set. KAKAO_CLIENT_SECRET is REQUIRED only if
# you enabled "Client Secret" in the Kakao console (off by default) — otherwise
# leave it blank.
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

# --- Google OAuth ----------------------------------------------
# OAuth 2.0 Web client from Google Cloud Console. Both client id and secret are
# required; the redirect URI must be registered as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- MinIO / S3 ------------------------------------------------
# TODO(oma-deferred): integrate minio when key is provisioned
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=jamye

# --- VAPID (Web Push) ------------------------------------------
# Real Web Push turns on as soon as both keys below are set (see
# vapid_enabled in core/config.py); with no keys, push sends are a silent
# no-op so the demo/dev environment works without VAPID provisioned.
#
# Generate a keypair (py_vapid ships as a transitive dep of pywebpush, no
# extra install needed) and paste the printed values below:
#
#   uv run --project backend python -c "
#   from py_vapid import Vapid02
#   from py_vapid.utils import b64urlencode
#   from cryptography.hazmat.primitives import serialization
#   v = Vapid02(); v.generate_keys()
#   priv = v.private_key.private_numbers().private_value.to_bytes(32, 'big')
#   pub = v.public_key.public_bytes(
#       serialization.Encoding.X962, serialization.PublicFormat.UncompressedPoint
#   )
#   print('VAPID_PRIVATE_KEY=', b64urlencode(priv))
#   print('VAPID_PUBLIC_KEY=', b64urlencode(pub))
#   "
#
# Both values are base64url-encoded (no padding). VAPID_PUBLIC_KEY is also
# served as-is via GET /api/push/vapid-public-key as the frontend's
# PushManager.subscribe applicationServerKey.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=smg981024@gmail.com

# --- App -------------------------------------------------------
APP_ENV=development
