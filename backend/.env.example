# ============================================================
# jamye-plz backend — environment variables
# Copy to .env and fill in real values for production.
# Demo/dev works without real OAuth/VAPID keys (fallback paths
# are active when keys are absent — see core/config.py).
# ============================================================

# --- Database --------------------------------------------------
DATABASE_URL=postgresql+asyncpg://jamye:password@localhost:5432/jamye

# --- JWT -------------------------------------------------------
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
# seconds (7 days default)
JWT_EXPIRE_SECONDS=604800

# --- CORS ------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:5173

# --- Kakao OAuth -----------------------------------------------
# REST API key (= KAKAO_CLIENT_ID) from developers.kakao.com. Real OAuth turns
# on as soon as KAKAO_CLIENT_ID is set. KAKAO_CLIENT_SECRET is REQUIRED only if
# you enabled "Client Secret" in the Kakao console (off by default) — otherwise
# leave it blank.
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

# --- Google OAuth ----------------------------------------------
# OAuth 2.0 Web client from Google Cloud Console. Both client id and secret are
# required; the redirect URI must be registered as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- MinIO / S3 --------------------------------------------------
# Real presigned uploads/reads turn on as soon as MINIO_ACCESS_KEY and
# MINIO_SECRET_KEY are both set; otherwise a deterministic local fallback
# URL is used so the demo works without MinIO provisioned. MINIO_ENDPOINT
# must be a browser-reachable address (not a container-internal hostname
# like "minio:9000") since it is embedded directly in the presigned URL.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=jamye

# --- VAPID (Web Push) ------------------------------------------
# TODO(oma-deferred): integrate vapid when key is provisioned
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=admin@example.com

# --- App -------------------------------------------------------
APP_ENV=development
